APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_DB=0

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=true

REVERB_APP_ID=chat-app
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

LIVEKIT_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_CA_BUNDLE=LIVEKIT_CA_BUNDLE=C:\Users\sumon\Desktop\Auto\venv\Lib\site-packages\pip\_vendor\certifi\cacert.pem

LIVEKIT_TOKEN_TTL=3600
LIVEKIT_ROOM_EMPTY_TIMEOUT=600
LIVEKIT_ROOM_MAX_PARTICIPANTS=12
LIVEKIT_ROOM_MAX_VIDEO_PUBLISHERS=4
LIVEKIT_ALLOWED_PUBLISH_SOURCES=camera,microphone

HORIZON_USE=default
HORIZON_PATH=horizon
HORIZON_PREFIX=laravel_horizon:
HORIZON_WAIT_SECONDS=60
HORIZON_MAX_PROCESSES=4
HORIZON_LOCAL_MAX_PROCESSES=2
HORIZON_SUPERVISOR_MEMORY=256
HORIZON_ALLOWED_EMAILS=
INITIAL_SUPER_ADMIN_USERNAMES=
INITIAL_ADMIN_USERNAMES=

ACTIVITYLOG_ENABLED=true
ACTIVITYLOG_CLEAN_AFTER_DAYS=365

VITE_APP_NAME="${APP_NAME}"
