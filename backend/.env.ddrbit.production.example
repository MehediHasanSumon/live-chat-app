APP_NAME="DDRBit Chat"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.ddrbit.com
FRONTEND_URL=https://app.ddrbit.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ddrbit_chat
DB_USERNAME=ddrbit_chat
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.ddrbit.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_DB=0

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@ddrbit.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=app.ddrbit.com
CORS_ALLOWED_ORIGINS=https://app.ddrbit.com
CORS_SUPPORTS_CREDENTIALS=true

REVERB_APP_ID=ddrbit-chat
REVERB_APP_KEY=replace-with-random-key
REVERB_APP_SECRET=replace-with-random-secret
REVERB_HOST=api.ddrbit.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

LIVEKIT_URL=https://your-livekit-host.example.com
LIVEKIT_API_KEY=replace-with-livekit-key
LIVEKIT_API_SECRET=replace-with-livekit-secret
LIVEKIT_CA_BUNDLE=
LIVEKIT_TOKEN_TTL=3600
LIVEKIT_ROOM_EMPTY_TIMEOUT=600
LIVEKIT_ROOM_MAX_PARTICIPANTS=12
LIVEKIT_ROOM_MAX_VIDEO_PUBLISHERS=4
LIVEKIT_ALLOWED_PUBLISH_SOURCES=camera,microphone

HORIZON_USE=default
HORIZON_PATH=horizon
HORIZON_PREFIX=ddrbit_horizon:
HORIZON_WAIT_SECONDS=60
HORIZON_MAX_PROCESSES=8
HORIZON_LOCAL_MAX_PROCESSES=2
HORIZON_SUPERVISOR_MEMORY=256
HORIZON_ALLOWED_EMAILS=admin@ddrbit.com

VITE_APP_NAME="${APP_NAME}"
