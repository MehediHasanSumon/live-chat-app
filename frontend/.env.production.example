# Frontend app origin
NEXT_PUBLIC_APP_URL=https://app.ddrbit.com

# Laravel backend base URL
NEXT_PUBLIC_API_BASE_URL=https://api.ddrbit.com

# Reverb / Echo client
NEXT_PUBLIC_REVERB_APP_KEY=replace-with-your-reverb-app-key
NEXT_PUBLIC_REVERB_HOST=api.ddrbit.com
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https

# Optional when Reverb is mounted under a custom reverse-proxy path
NEXT_PUBLIC_REVERB_PATH=

# LiveKit URL. Keep this aligned with backend LIVEKIT_URL and never expose API secrets here.
NEXT_PUBLIC_LIVEKIT_URL=https://your-livekit-host.example.com
